# YPT Discord Study Bot — Environment Variables
# Copy this file to .env and fill in your values.

BOT_TOKEN=your_discord_bot_token_here
LEADERBOARD_CHANNEL_ID=000000000000000000
LOG_CHANNEL_ID=000000000000000000
CELEBRATION_CHANNEL_ID=000000000000000000

# Valence Task Bot — Environment Variables
TASK_BOT_TOKEN=your_task_bot_token_here

# Firebase Configuration
FIREBASE_CREDENTIALS={"type": "service_account", "project_id": "your_project_id", "private_key_id": "your_private_key_id", "private_key": "your_private_key", "client_email": "your_client_email"}
